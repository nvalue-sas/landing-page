---
import HeroButtons from "./HeroButtons.astro";
import { RuntimeCard } from "@/components/hero/RuntimeCard";
import { useTranslations } from "@/i18n/utils";

const t = useTranslations(Astro.currentLocale);
---

<div
  class="mx-auto grid w-full max-w-7xl grid-cols-1 items-center gap-12 px-6 lg:grid-cols-[3fr_2fr] lg:gap-16"
>
  <!-- Left column: copy -->
  <div class="relative z-20 text-left">
    <!-- Badge -->
    <div
      class="animate-blurred-fade-in animate-duration-500 mb-6 inline-flex items-center gap-2 rounded-full bg-transparent px-3.5 py-1.5 ring-1 ring-black/10 ring-inset backdrop-blur-md [box-shadow:inset_0_1px_0_0_rgba(255,255,255,0.6),0_8px_20px_-10px_rgba(0,0,0,0.25)] dark:ring-white/12 dark:[box-shadow:inset_0_1px_0_0_rgba(255,255,255,0.12),0_14px_30px_-12px_rgba(0,0,0,0.8)]"
    >
      <span
        class="h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-500 [box-shadow:0_0_8px_1px_rgba(34,211,238,0.6)] dark:bg-cyan-400"
      ></span>
      <span
        class="font-mono text-[10px] tracking-[0.15em] text-secondary-500 uppercase dark:text-secondary-400"
      >
        {t("hero.badge")}
      </span>
    </div>

    <!-- Heading -->
    <h1
      class="animate-blurred-fade-in animate-delay-150 animate-duration-500 text-[clamp(2.2rem,5.6vw,4.4rem)] leading-[1.02] font-semibold tracking-[-0.02em] text-balance text-secondary-900 dark:text-secondary-100"
    >
      {t("hero.heading_before")}<span class="relative whitespace-nowrap"
        ><span
          class="text-cyan-500 [text-shadow:0_0_30px_rgba(6,182,212,0.5)] dark:text-cyan-400"
          >{t("hero.heading_highlight")}</span
        ><span
          aria-hidden="true"
          class="absolute -bottom-1 left-0 h-px w-full bg-linear-to-r from-transparent via-cyan-500 to-transparent dark:via-cyan-400"
        ></span></span
      >{t("hero.heading_after")}
    </h1>

    <!-- Subtitle -->
    <p
      class="animate-blurred-fade-in animate-delay-300 animate-duration-500 mt-6 max-w-xl text-base leading-relaxed text-pretty text-secondary-400 sm:text-lg dark:text-secondary-300"
    >
      {t("hero.subtitle")}
    </p>

    <!-- CTA Buttons -->
    <div
      class="animate-blurred-fade-in animate-delay-500 animate-duration-500 mt-8"
    >
      <HeroButtons
        scheduleLabel={t("hero.schedule_conversation")}
        viewWorkLabel={t("hero.view_work")}
        scheduleEmail="info@nvalue.com.co"
      />
    </div>
  </div>

  <!-- Right column: nValue Runtime card -->
  <div
    class="animate-blurred-fade-in animate-delay-500 animate-duration-500 relative z-20"
  >
    <RuntimeCard client:load />
  </div>
</div>

