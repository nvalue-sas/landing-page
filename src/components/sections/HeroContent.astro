---
import { Sparkles } from "@lucide/astro";
import { HeroButtons } from "./HeroButtons";
---

<div class="w-full max-w-7xl">
  <div class="relative z-20 text-center">
    <!-- Badge -->
    <div
      class="animate-blurred-fade-in animate-duration-500 mb-6 inline-flex items-center gap-2 rounded-full border border-cyan-500/30 bg-cyan-500/5 px-3 py-1.5 shadow-lg shadow-cyan-500/10 backdrop-blur-sm sm:mb-8 sm:px-4 sm:py-2"
    >
      <Sparkles
        class="h-3.5 w-3.5 text-cyan-600 sm:h-4 sm:w-4 dark:text-cyan-400"
      />
      <span
        class="text-xs font-medium text-cyan-600 sm:text-sm dark:text-cyan-300"
        >Desarrollo de Software Impulsado por IA</span
      >
    </div>

    <!-- Heading -->
    <h1
      class="animate-blurred-fade-in animate-delay-150 animate-duration-500 text-4xl leading-tight font-bold tracking-tight text-balance sm:text-5xl md:text-6xl lg:text-7xl"
    >
      <span
        class="bg-linear-to-r from-cyan-400 via-cyan-300 to-blue-400 bg-clip-text text-transparent drop-shadow-[0_0_30px_rgba(6,182,212,0.3)]"
      >
        You Dream It.
      </span>
      <br />
      <span class="text-secondary-900 dark:text-secondary-100">We Code It.</span
      >
    </h1>
  </div>

  <!-- Subtitle -->
  <p
    class="animate-blurred-fade-in animate-delay-300 animate-duration-500 mx-auto my-8 max-w-3xl text-center text-xl leading-relaxed text-pretty text-secondary-400 md:mt-12 md:text-2xl dark:text-secondary-100"
  >
    <span class="text-secondary-900 dark:text-secondary-100">
      Transformamos tus ideas en productos de software de clase mundial.
    </span>
  </p>
  <!-- CTA Buttons -->
  <div class="animate-blurred-fade-in animate-delay-500 animate-duration-500">
    <HeroButtons client:load />
  </div>
</div>
