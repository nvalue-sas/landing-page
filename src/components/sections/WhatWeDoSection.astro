---
import { useTranslations } from "@/i18n/utils";

const t = useTranslations(Astro.currentLocale);

const blocks = [
  {
    k: "01",
    title: t("whatwedo.block1_title"),
    desc: t("whatwedo.block1_desc"),
  },
  {
    k: "02",
    title: t("whatwedo.block2_title"),
    desc: t("whatwedo.block2_desc"),
  },
  {
    k: "03",
    title: t("whatwedo.block3_title"),
    desc: t("whatwedo.block3_desc"),
  },
];
---

<section
  id="what-we-do"
  class="relative py-24 sm:py-32"
>
  <div class="mx-auto max-w-7xl px-6">
    <!-- Section label -->
    <div
      data-reveal
      class="flex items-center gap-3 font-mono text-[11px] tracking-[0.22em] text-cyan-600 uppercase opacity-0 dark:text-cyan-400"
    >
      <span>01</span>
      <span class="h-px w-8 bg-cyan-500/50 dark:bg-cyan-400/50"></span>
      <span>{t("whatwedo.label")}</span>
    </div>

    <!-- Heading -->
    <h2
      data-reveal
      class="animate-delay-150 mt-6 max-w-3xl text-[clamp(1.8rem,3.6vw,2.8rem)] leading-tight font-semibold tracking-tight text-balance text-secondary-900 opacity-0 dark:text-secondary-100"
    >
      {t("whatwedo.heading")}
    </h2>

    <!-- Cards: hairline seams via gap-px over a border-colored track.
         El bloque completo se revela como una sola unidad para que el fondo
         gris del track y las tarjetas aparezcan juntos (si no, el gris queda
         visible solo mientras las tarjetas están en opacity-0). -->
    <div
      data-reveal
      class="animate-delay-300 mt-14 grid gap-px overflow-hidden rounded-xl border border-secondary-300/70 bg-secondary-300/70 opacity-0 md:grid-cols-3 dark:border-white/10 dark:bg-white/10"
    >
      {
        blocks.map((b) => (
          <article class="group relative bg-gray-50 p-7 transition-colors duration-300 hover:bg-white dark:bg-black dark:hover:bg-white/[0.03]">
            <div class="flex items-center gap-3 font-mono text-[11px] tracking-[0.2em] text-cyan-600 uppercase dark:text-cyan-400">
              <span>{b.k}</span>
              <span class="h-px w-6 bg-cyan-500/50 dark:bg-cyan-400/50" />
            </div>
            <h3 class="mt-5 text-xl font-semibold text-secondary-900 dark:text-secondary-100">
              {b.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-secondary-500 dark:text-secondary-400">
              {b.desc}
            </p>
            {/* Underline that draws in on hover */}
            <div
              aria-hidden="true"
              class="absolute inset-x-7 bottom-0 h-px origin-left scale-x-0 bg-cyan-500 transition-transform duration-500 group-hover:scale-x-100 dark:bg-cyan-400"
            />
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Reveal on scroll: los elementos parten en opacity-0 y, al entrar en
  // viewport, se les aplica la utilidad animate-fade-in-up del plugin
  // (que ya incluye fill-mode: both, así el estado final se sostiene).
  const revealables = document.querySelectorAll<HTMLElement>(
    "#what-we-do [data-reveal]",
  );

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add(
          "animate-fade-in-up",
          "animate-duration-700",
        );
        observer.unobserve(entry.target);
      });
    },
    { threshold: 0.2 },
  );

  revealables.forEach((el) => observer.observe(el));
</script>
