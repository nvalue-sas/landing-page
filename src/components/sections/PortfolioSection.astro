---
import DashboardMockup from "./DashboardMockup.astro";
import { BriefcaseBusiness, MoveRight, ChevronRight } from "@lucide/astro";
---

<section id="portfolio" class="py-16 lg:py-24">
  <div class="container mx-auto max-w-7xl px-6">
    <div
      class="flex flex-col items-center gap-12 lg:flex-row lg:items-center lg:justify-between lg:gap-16"
    >
      <!-- Left Side: Text Content -->
      <div class="w-full text-center lg:w-1/2 lg:text-left">
        <!-- Badge/Label -->
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-teal-500/30 bg-teal-500/5 px-4 py-2 shadow-lg shadow-teal-500/10 backdrop-blur-sm"
        >
          <BriefcaseBusiness class="h-4 w-4 text-teal-600 dark:text-teal-400" />
          <span class="text-sm font-medium text-teal-600 dark:text-teal-300"
            >Portafolio</span
          >
        </div>

        <!-- Main Title -->
        <h2
          class="font-title mb-6 text-4xl leading-tight tracking-tight sm:text-5xl lg:text-6xl"
        >
          <span class="font-bold text-secondary-900 dark:text-secondary-100"
            >Nuestros Proyectos</span
          >
          <br />
          <span class="font-light text-secondary-700 dark:text-gray-300"
            >Demuestran nuestra experiencia</span
          >
        </h2>

        <!-- Description Paragraph -->
        <p
          class="mb-8 text-lg leading-relaxed text-secondary-400 sm:text-xl dark:text-gray-400"
        >
          Soluciones digitales que impulsan el crecimiento. Desde aplicaciones
          web hasta dashboards analíticos, transformamos ideas en productos
          funcionales y escalables.
        </p>

        <!-- CTA Buttons -->
        <div
          class="flex flex-col items-center gap-4 sm:flex-row lg:justify-start"
        >
          <a
            href="#"
            class="group inline-flex items-center gap-2 rounded-xl bg-linear-to-r from-teal-600 to-emerald-600 px-8 py-4 font-semibold text-white shadow-lg shadow-teal-500/25 transition-all duration-300 hover:scale-[1.02] hover:shadow-xl hover:shadow-teal-500/40 active:scale-[0.98]"
          >
            <span>Ver Proyectos</span>
            <MoveRight
              class="h-5 w-5 transition-transform group-hover:translate-x-1"
            />
          </a>
          <a
            href="#contact"
            class="inline-flex items-center gap-2 rounded-xl border border-transparent bg-transparent px-8 py-4 text-teal-600 transition-all hover:scale-[1.02] hover:bg-teal-500/10 dark:text-teal-400 dark:hover:border-teal-400/50"
          >
            <span>Contactar</span>
            <ChevronRight
              class="h-5 w-5 transition-transform group-hover:translate-x-1"
            />
          </a>
        </div>
      </div>

      <!-- Right Side: Dashboard Mockup -->
      <div class="w-full lg:w-1/2">
        <DashboardMockup />
      </div>
    </div>

    <!-- Tech Stack Marquee -->
    <div class="marquee-mask mt-20 w-full overflow-hidden py-8">
      <div class="hover:paused flex w-max animate-marquee-scroll gap-16">
        <!-- Group 1 -->
        <div class="flex shrink-0 items-center gap-16">
          <img src="/stack/java.svg" alt="Java" class="marquee-logo h-10" />
          <img
            src="/stack/spring-boot.svg"
            alt="Spring Boot"
            class="marquee-logo h-10"
          />
          <img
            src="/stack/jakarta-ee.svg"
            alt="Jakarta EE"
            class="marquee-logo h-10"
          />
          <img
            src="/stack/python-3.svg"
            alt="Python"
            class="marquee-logo h-10"
          />
          <img
            src="/stack/astro-logo-light-gradient.svg"
            alt="Astro"
            class="marquee-logo hidden h-10 dark:block"
          />
          <img
            src="/stack/astro-logo-dark.svg"
            alt="Astro"
            class="marquee-logo h-10 dark:hidden"
          />
          <img src="/stack/react.svg" alt="React" class="marquee-logo h-10" />
          <img
            src="/stack/nextjs.svg"
            alt="Next.js"
            class="marquee-logo h-10 fill-white dark:fill-black"
          />
        </div>

        <!-- Group 2 (duplicate for seamless loop) -->
        <div class="flex shrink-0 items-center gap-16" aria-hidden="true">
          <img src="/stack/java.svg" alt="Java" class="marquee-logo h-10" />
          <img
            src="/stack/spring-boot.svg"
            alt="Spring Boot"
            class="marquee-logo h-10"
          />
          <img
            src="/stack/jakarta-ee.svg"
            alt="Jakarta EE"
            class="marquee-logo h-10"
          />
          <img
            src="/stack/python-3.svg"
            alt="Python"
            class="marquee-logo h-10"
          />
          <img
            src="/stack/astro-logo-light-gradient.svg"
            alt="Astro"
            class="marquee-logo h-10 dark:hidden"
          />
          <img
            src="/stack/astro-logo-dark.svg"
            alt="Astro"
            class="marquee-logo hidden h-10 dark:block"
          />
          <img src="/stack/react.svg" alt="React" class="marquee-logo h-10" />
          <img
            src="/stack/nextjs.svg"
            alt="Next.js"
            class="marquee-logo h-10 fill-white dark:fill-black"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-mask {
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
  }

  .marquee-logo {
    width: auto;
    filter: grayscale(100%);
    opacity: 0.6;
    transition: all 0.3s ease;
  }

  .marquee-logo:hover {
    filter: grayscale(0%);
    opacity: 1;
  }

  :global(.dark) .marquee-logo {
    filter: grayscale(100%) brightness(2);
  }

  :global(.dark) .marquee-logo:hover {
    filter: grayscale(0%) brightness(1);
  }
</style>
