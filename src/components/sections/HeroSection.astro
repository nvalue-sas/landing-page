---
import { Vortex } from "../ui/vortex";
import HeroContent from "./HeroContent.astro";
---

<section
  id="hero"
  class="relative mx-auto flex min-h-screen flex-col items-center justify-center overflow-hidden px-4 py-20 sm:px-6 md:py-24 lg:px-8"
>
  <!-- Vortex solo en dark mode -->
  <div class="hidden dark:block">
    <Vortex client:load baseHue={185}>
      <HeroContent />
    </Vortex>
  </div>

  <!-- Contenido sin Vortex en light mode -->
  <div class="block dark:hidden">
    <HeroContent />
  </div>
</section>
