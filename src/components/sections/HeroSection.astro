---
import { Sparkles, ArrowRight, Code } from "@lucide/astro";
---

<section
  id="hero"
  class="relative mx-auto flex min-h-screen flex-col items-center justify-center overflow-hidden px-4 py-20 sm:px-6 md:py-24 lg:px-8"
>
  <div class="w-full max-w-7xl">
    <div class="relative z-20 text-center">
      <!-- Badge -->
      <div
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-cyan-500/30 bg-cyan-500/5 px-3 py-1.5 shadow-lg shadow-cyan-500/10 backdrop-blur-sm sm:mb-8 sm:px-4 sm:py-2"
      >
        <Sparkles
          class="h-3.5 w-3.5 text-cyan-600 sm:h-4 sm:w-4 dark:text-cyan-400"
        />
        <span
          class="text-xs font-medium text-cyan-600 sm:text-sm dark:text-cyan-300"
          >Desarrollo de Software Impulsado por IA</span
        >
      </div>

      <!-- Heading -->
      <h1
        class="text-4xl leading-tight font-bold tracking-tight text-balance sm:text-5xl md:text-6xl lg:text-7xl"
      >
        <span
          class="bg-gradient-to-r from-cyan-400 via-cyan-300 to-blue-400 bg-clip-text text-transparent drop-shadow-[0_0_30px_rgba(6,182,212,0.3)]"
        >
          You Dream It.
        </span>
        <br />
        <span class="text-secondary-900 dark:text-secondary-100"
          >We Code It.</span
        >
      </h1>

      <h1
        class="hidden mask-b-from-90% mask-b-to-100% text-center text-4xl font-extrabold tracking-tight text-slate-700 sm:text-5xl md:text-6xl lg:text-7xl dark:text-slate-200"
      >
        <span
          class="bg-linear-to-r from-cyan-500 to-blue-500 bg-clip-text text-transparent"
          >You Dream It.</span
        >
        <br />
        We Code It.
      </h1>
    </div>

    <!-- Subtitle -->
    <p
      class="mx-auto my-8 max-w-3xl text-center text-xl leading-relaxed text-pretty text-secondary-400 md:mt-12 md:text-2xl dark:text-secondary-100"
    >
      Transformamos tus ideas en productos de software de clase mundial.
      Desarrollo a la medida con tecnología de vanguardia.
    </p>

    <!-- CTA Buttons -->
    <div
      class="flex flex-col items-center justify-center gap-4 pt-4 sm:flex-row"
    >
      <button
        class="group relative overflow-hidden rounded-xl bg-linear-to-r from-cyan-500 to-blue-600 px-8 py-4 font-semibold text-white transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl hover:shadow-cyan-500/40 active:scale-[0.98]"
      >
        <span class="relative z-10 flex items-center gap-2">
          <Sparkles
            class="h-5 w-5 transition-transform group-hover:rotate-12"
          />
          Iniciar Proyecto con IA
          <ArrowRight
            class="h-5 w-5 transition-transform group-hover:translate-x-1"
          />
        </span>
      </button>
      <button
        class="rounded-xl border-gray-700 bg-transparent px-8 py-4 text-cyan-600 transition-all hover:scale-[1.02] hover:bg-cyan-500/10 dark:text-secondary-100 dark:hover:border-cyan-400 dark:hover:text-cyan-400"
      >
        <span class="relative z-10 flex items-center gap-2">
          <Code class="h-5 w-5" />
          Ver Nuestro Trabajo
        </span>
      </button>
    </div>
  </div>
</section>
