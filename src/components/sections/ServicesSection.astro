---
import { services } from "@/data/services.js";
import { getColorClass } from "@/utils/ServicesStylesHelper.js";
import * as LucideIcons from "@lucide/astro";
---

<section
  id="services"
  class="relative py-10 before:pointer-events-none before:absolute before:inset-0 before:bg-[radial-gradient(var(--pattern-fg)_1px,transparent_0)] before:bg-size-[10px_10px] before:bg-fixed before:[--pattern-fg:var(--color-gray-950)]/5 before:[mask-image:linear-gradient(to_bottom,transparent_0%,black_30%)] dark:before:[--pattern-fg:var(--color-white)]/10"
>
  <div
    class="container mx-auto max-w-7xl px-6 py-10 text-slate-700 dark:text-secondary-200"
  >
    <div class="mx-auto mb-16 max-w-3xl text-center">
      <h2 class="animate-on-scroll mb-4 text-3xl font-bold md:text-4xl">
        Nuestros Servicios
      </h2>
      <div class="mx-auto mb-6 h-1 w-20 bg-primary-500"></div>
      <p
        class="animate-on-scroll text-lg text-slate-700 dark:text-secondary-200"
      >
        Ofrecemos soluciones de software personalizadas que abordan desafíos
        empresariales complejos e impulsan la transformación digital.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service, index) => {
          const IconComponent = (LucideIcons as any)[service.icon];
          const titleHoverColor = service.color === "primary"
            ? "dark:group-hover:text-cyan-400"
            : service.color === "secondary"
            ? "dark:group-hover:text-teal-400"
            : "dark:group-hover:text-pink-400";
          return (
            <div
              class={`group animate-on-scroll rounded-lg border p-6 ${getColorClass(service.color)}`}
              style={`animation-delay: ${index * 100}ms`}
            >
              <div class="mb-4">
                <div
                  class={`flex h-12 w-12 items-center justify-center rounded-lg ${service.color === "primary" ? "bg-primary-400/10" : service.color === "secondary" ? "bg-teal-400/10" : "bg-pink-400/10"}`}
                >
                  <IconComponent class="h-6 w-6" />
                </div>
              </div>
              <h3 class={`mb-3 text-xl font-semibold transition-colors duration-300 dark:text-secondary-100 ${titleHoverColor}`}>
                {service.title}
              </h3>
              <p class="text-slate-700 dark:text-gray-400">
                {service.description}
              </p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
