---
import {
  LayoutDashboard,
  House,
  ChartColumn,
  FolderOpen,
  Users,
  Settings,
  Search,
  Bell,
  Calendar,
  EllipsisVertical,
  Layers,
  Smartphone,
  Sparkles,
} from "@lucide/astro";
---

<div class="relative mx-auto w-full max-w-4xl">
  <!-- Decorative Elements (Now inside the relative container) -->
  <div
    class="absolute -top-6 -right-6 -z-10 h-32 w-32 rounded-full bg-linear-to-br from-primary-400/20 to-cyan-400/20 blur-3xl"
  >
  </div>
  <div
    class="absolute -bottom-6 -left-6 -z-10 h-40 w-40 rounded-full bg-linear-to-br from-purple-400/20 to-pink-400/20 blur-3xl"
  >
  </div>

  <!-- Browser Window Frame -->
  <div
    class="relative z-10 overflow-hidden rounded-2xl border border-gray-200/60 bg-white shadow-2xl dark:border-gray-700/50 dark:bg-gray-900"
  >
    <!-- Browser Header -->
    <div
      class="flex items-center gap-2 border-b border-gray-200/60 bg-gray-100/80 px-4 py-2.5 dark:border-gray-700/50 dark:bg-gray-800/80"
    >
      <div class="flex gap-1.5">
        <div class="h-3 w-3 rounded-full bg-red-400"></div>
        <div class="h-3 w-3 rounded-full bg-yellow-400"></div>
        <div class="h-3 w-3 rounded-full bg-green-400"></div>
      </div>
      <div
        class="ml-4 flex-1 rounded-md bg-white/60 px-3 py-1 text-xs text-gray-500 dark:bg-gray-700/60 dark:text-gray-400"
      >
        dashboard.nvalue.dev
      </div>
    </div>

    <!-- Dashboard Layout -->
    <div class="flex">
      <!-- Sidebar -->
      <div
        class="hidden w-14 shrink-0 flex-col border-r border-gray-200/60 bg-gray-50/50 py-4 sm:flex dark:border-gray-700/40 dark:bg-gray-800/30"
      >
        <!-- Logo -->
        <div class="mb-6 flex justify-center">
          <div
            class="flex h-9 w-9 items-center justify-center rounded-lg bg-black text-secondary-100 dark:bg-secondary-100 dark:text-secondary-900"
          >
            <LayoutDashboard class="h-5 w-5" stroke-width={1.5} />
          </div>
        </div>

        <!-- Nav Items -->
        <nav class="flex flex-1 flex-col items-center gap-2">
          <button
            class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600 transition-all dark:bg-emerald-900/40 dark:text-emerald-400"
            aria-label="Dashboard"
          >
            <House class="h-5 w-5" stroke-width={1.5} />
          </button>
          <button
            class="flex h-10 w-10 items-center justify-center rounded-lg text-gray-400 transition-all hover:bg-gray-200/60 hover:text-gray-600 dark:hover:bg-gray-700/40 dark:hover:text-gray-300"
            aria-label="Analytics"
          >
            <ChartColumn class="h-5 w-5" stroke-width={1.5} />
          </button>
          <button
            class="flex h-10 w-10 items-center justify-center rounded-lg text-gray-400 transition-all hover:bg-gray-200/60 hover:text-gray-600 dark:hover:bg-gray-700/40 dark:hover:text-gray-300"
            aria-label="Projects"
          >
            <FolderOpen class="h-5 w-5" stroke-width={1.5} />
          </button>
          <button
            class="flex h-10 w-10 items-center justify-center rounded-lg text-gray-400 transition-all hover:bg-gray-200/60 hover:text-gray-600 dark:hover:bg-gray-700/40 dark:hover:text-gray-300"
            aria-label="Team"
          >
            <Users class="h-5 w-5" stroke-width={1.5} />
          </button>
        </nav>

        <!-- Bottom Nav -->
        <div class="flex flex-col items-center gap-2">
          <button
            class="flex h-10 w-10 items-center justify-center rounded-lg text-gray-400 transition-all hover:bg-gray-200/60 hover:text-gray-600 dark:hover:bg-gray-700/40 dark:hover:text-gray-300"
            aria-label="Settings"
          >
            <Settings class="h-5 w-5" stroke-width={1.5} />
          </button>
          <img src="/avatar.webp" alt="Avatar" class="h-8 w-8 rounded-full" />
        </div>
      </div>

      <!-- Main Content -->
      <div class="flex-1 p-4 lg:p-5">
        <!-- Header -->
        <div class="mb-4 flex items-center justify-between">
          <div>
            <p class="text-xs text-gray-500 dark:text-gray-400">Overview</p>
            <h1
              class="text-base font-semibold text-gray-800 lg:text-lg dark:text-white"
            >
              Bienvenido a nValue
            </h1>
          </div>
          <div class="flex items-center gap-2">
            <!-- Search -->
            <div
              class="hidden w-36 items-center gap-2 rounded-lg border border-gray-200/60 bg-gray-50/50 px-3 py-1.5 text-xs text-gray-400 sm:flex dark:border-gray-700/40 dark:bg-gray-800/50"
            >
              <Search class="h-3.5 w-3.5" />
              <span>Buscar...</span>
            </div>
            <!-- Notification -->
            <button
              class="relative flex h-8 w-8 items-center justify-center rounded-lg text-gray-400 transition-all hover:bg-gray-100 dark:hover:bg-gray-800"
            >
              <Bell class="h-4 w-4" />
              <span
                class="absolute top-1 right-1 h-2 w-2 rounded-full bg-red-500 ring-2 ring-white dark:ring-gray-900"
              ></span>
            </button>
          </div>
        </div>

        <!-- Tabs & Date Range -->
        <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
          <!-- Tabs -->
          <div
            class="dashboard-tabs flex rounded-lg bg-gray-100/80 p-1 dark:bg-gray-800/60"
          >
            <input
              type="radio"
              name="dashboard-period"
              id="tab-weekly"
              class="peer/weekly hidden"
            />
            <label
              for="tab-weekly"
              class="cursor-pointer rounded-md px-3 py-1 text-xs font-medium text-gray-500 transition-all peer-checked/weekly:bg-white peer-checked/weekly:text-gray-800 peer-checked/weekly:shadow-sm hover:text-gray-700 dark:text-gray-400 dark:peer-checked/weekly:bg-gray-700 dark:peer-checked/weekly:text-white dark:hover:text-gray-300"
            >
              Semanal
            </label>
            <input
              type="radio"
              name="dashboard-period"
              id="tab-monthly"
              class="peer/monthly hidden"
              checked
            />
            <label
              for="tab-monthly"
              class="cursor-pointer rounded-md px-3 py-1 text-xs font-medium text-gray-500 transition-all peer-checked/monthly:bg-white peer-checked/monthly:text-gray-800 peer-checked/monthly:shadow-sm hover:text-gray-700 dark:text-gray-400 dark:peer-checked/monthly:bg-gray-700 dark:peer-checked/monthly:text-white dark:hover:text-gray-300"
            >
              Mensual
            </label>
            <input
              type="radio"
              name="dashboard-period"
              id="tab-yearly"
              class="peer/yearly hidden"
            />
            <label
              for="tab-yearly"
              class="cursor-pointer rounded-md px-3 py-1 text-xs font-medium text-gray-500 transition-all peer-checked/yearly:bg-white peer-checked/yearly:text-gray-800 peer-checked/yearly:shadow-sm hover:text-gray-700 dark:text-gray-400 dark:peer-checked/yearly:bg-gray-700 dark:peer-checked/yearly:text-white dark:hover:text-gray-300"
            >
              Anual
            </label>
          </div>
          <!-- Date Range -->
          <div
            class="flex items-center gap-2 rounded-lg border border-gray-200/60 px-2.5 py-1.5 text-xs text-gray-500 dark:border-gray-700/40 dark:text-gray-400"
          >
            <span class="hidden sm:inline">01/01/2025 - 31/12/2025</span>
            <span class="sm:hidden">Dic 2025</span>
            <Calendar class="h-3.5 w-3.5" />
          </div>
        </div>

        <!-- Chart Section -->
        <div
          class="mb-4 rounded-xl border border-gray-200/60 bg-white p-4 dark:border-gray-700/40 dark:bg-gray-800/40"
        >
          <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
            <h2 class="text-sm font-semibold text-gray-800 dark:text-white">
              Analytics de Proyectos
            </h2>
            <!-- Legend -->
            <div class="flex flex-wrap gap-3 text-xs">
              <div class="flex items-center gap-1.5">
                <div class="h-2.5 w-2.5 rounded-full bg-slate-400"></div>
                <span class="text-gray-600 dark:text-gray-300">Desarrollo</span>
              </div>
              <div class="flex items-center gap-1.5">
                <div class="h-2.5 w-2.5 rounded-full bg-slate-300"></div>
                <span class="text-gray-600 dark:text-gray-300">Diseño</span>
              </div>
              <div class="flex items-center gap-1.5">
                <div class="h-2.5 w-2.5 rounded-full bg-slate-200"></div>
                <span class="text-gray-600 dark:text-gray-300">Consultoría</span
                >
              </div>
            </div>
          </div>

          <!-- Chart with Y-axis labels -->
          <div class="flex gap-2">
            <!-- Y-axis -->
            <div
              class="flex flex-col justify-between py-1 text-right text-[10px] text-gray-400"
            >
              <span>30k</span>
              <span>20k</span>
              <span>10k</span>
              <span>0</span>
            </div>

            <!-- Bars -->
            <div class="flex flex-1 items-end justify-between gap-1 sm:gap-2">
              {
                [
                  { h1: 35, h2: 20, h3: 15, label: "Ene" },
                  { h1: 50, h2: 25, h3: 20, label: "Feb" },
                  { h1: 40, h2: 30, h3: 25, label: "Mar" },
                  { h1: 55, h2: 20, h3: 30, label: "Abr" },
                  { h1: 45, h2: 35, h3: 20, label: "May" },
                  { h1: 60, h2: 25, h3: 35, label: "Jun" },
                  { h1: 70, h2: 40, h3: 25, label: "Jul" },
                  { h1: 65, h2: 30, h3: 40, label: "Ago" },
                  { h1: 55, h2: 45, h3: 30, label: "Sep" },
                  { h1: 75, h2: 35, h3: 35, label: "Oct" },
                  { h1: 80, h2: 40, h3: 30, label: "Nov" },
                  { h1: 85, h2: 45, h3: 40, label: "Dic" },
                ].map((bar) => (
                  <div class="group flex flex-1 flex-col items-center gap-1">
                    <div class="relative flex w-full flex-col items-center">
                      {/* Tooltip */}
                      <div class="pointer-events-none absolute -top-12 left-1/2 z-10 -translate-x-1/2 scale-0 rounded-md bg-gray-800 px-2 py-1 text-[10px] whitespace-nowrap text-white opacity-0 shadow-lg transition-all duration-200 group-hover:scale-100 group-hover:opacity-100 dark:bg-gray-700">
                        <div class="font-medium">{bar.label} 2024</div>
                        <div class="text-gray-300">
                          Total: ${bar.h1 + bar.h2 + bar.h3}k
                        </div>
                      </div>
                      {/* Stacked bars */}
                      <div class="flex w-full flex-col items-center transition-transform duration-200 group-hover:scale-105">
                        <div
                          class="w-full rounded-t bg-slate-200 transition-all dark:bg-teal-200"
                          style={`height: ${bar.h3 * 0.8}px`}
                        />
                        <div
                          class="w-full bg-slate-300 transition-all dark:bg-teal-300"
                          style={`height: ${bar.h2 * 0.8}px`}
                        />
                        <div
                          class="w-full rounded-b bg-slate-400 transition-all dark:bg-teal-400"
                          style={`height: ${bar.h1 * 0.8}px`}
                        />
                      </div>
                    </div>
                    <span class="text-[10px] text-gray-400">{bar.label}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Bottom Grid: Table & Portfolio -->
        <div class="grid grid-cols-1">
          <!-- Transactions Table -->
          <div
            class="rounded-xl border border-gray-200/60 bg-white p-3 dark:border-gray-700/40 dark:bg-gray-800/40"
          >
            <div class="mb-3 flex items-center justify-between">
              <h3 class="text-sm font-semibold text-gray-800 dark:text-white">
                Portfolio
              </h3>
              <button
                class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
              >
                <EllipsisVertical class="h-4 w-4" />
              </button>
            </div>

            <!-- Table -->
            <div class="overflow-x-auto">
              <table class="w-full text-left text-xs">
                <thead>
                  <tr
                    class="border-b border-gray-200/60 dark:border-gray-700/40"
                  >
                    <th
                      class="hidden pb-2 font-medium text-gray-500 sm:table-cell dark:text-gray-400"
                    >
                      Proyecto
                    </th>
                    <th
                      class="hidden pb-2 font-medium text-gray-500 sm:table-cell dark:text-gray-400"
                    >
                      Tipo
                    </th>
                    <th
                      class="pb-2 font-medium text-gray-500 dark:text-gray-400"
                      >Estado</th
                    >
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-gray-700/40">
                  <tr
                    class="group transition-colors hover:bg-gray-50/50 dark:hover:bg-gray-700/20"
                  >
                    <td
                      class="py-2.5 text-left font-medium text-gray-800 dark:text-white"
                    >
                      Geoland
                    </td>
                    <td class="hidden py-2.5 sm:table-cell">
                      <div class="flex items-center gap-1">
                        <Smartphone class="h-3.5 w-3.5 text-rose-500" />
                        <span class="text-gray-600 dark:text-secondary-100"
                          >Mobile</span
                        >
                      </div>
                    </td>
                    <td class="py-2.5">
                      <span
                        class="rounded-full bg-yellow-100 px-2 py-0.5 text-[10px] font-medium text-yellow-600 dark:bg-yellow-900/40 dark:text-yellow-400"
                      >
                        En Proceso
                      </span>
                    </td>
                  </tr>
                  <tr
                    class="group transition-colors hover:bg-gray-50/50 dark:hover:bg-gray-700/20"
                  >
                    <td
                      class="py-2.5 text-left font-medium text-gray-800 dark:text-white"
                    >
                      Radicacion Electronica
                    </td>
                    <td class="hidden py-2.5 sm:table-cell">
                      <div class="flex items-center gap-1">
                        <Layers class="h-3.5 w-3.5 text-purple-500" />
                        <span class="text-gray-600 dark:text-secondary-100"
                          >Web App</span
                        >
                      </div>
                    </td>
                    <td class="py-2.5">
                      <span
                        class="rounded-full bg-green-100 px-2 py-0.5 text-[10px] font-medium text-green-600 dark:bg-green-900/40 dark:text-green-400"
                      >
                        Completado
                      </span>
                    </td>
                  </tr>
                </tbody>
                <tr
                  class="group transition-colors hover:bg-gray-50/50 dark:hover:bg-gray-700/20"
                >
                  <td
                    class="py-2.5 text-left font-medium text-gray-800 dark:text-white"
                  >
                    Muevete AI
                  </td>
                  <td class="hidden py-2.5 sm:table-cell">
                    <div class="flex items-center gap-1">
                      <Sparkles class="h-3.5 w-3.5 text-emerald-500" />
                      <span class="text-gray-600 dark:text-secondary-100"
                        >Web App + AI</span
                      >
                    </div>
                  </td>
                  <td class="py-2.5">
                    <span
                      class="rounded-full bg-primary-100 px-2 py-0.5 text-[10px] font-medium text-primary-600 dark:bg-primary-900/40 dark:text-primary-400"
                    >
                      Nuevo
                    </span>
                  </td>
                </tr>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Decorative Elements -->

<style>
  /* Smooth animation for bars on page load */
  @keyframes barGrow {
    from {
      transform: scaleY(0);
    }
    to {
      transform: scaleY(1);
    }
  }

  .group:hover .bg-primary-500,
  .group:hover .bg-cyan-400,
  .group:hover .bg-purple-400 {
    filter: brightness(1.1);
  }
</style>
