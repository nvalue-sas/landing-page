---
import { navItems } from "./navItems";
---

<div class="hidden items-center space-x-8 md:flex">
  {
    navItems.map((item) => (
      <a
        href={item.href}
        class="text-base font-medium text-secondary-700 transition-colors hover:text-primary-600 dark:text-secondary-100 dark:hover:text-cyan-400"
      >
        {item.name}
      </a>
    ))
  }
</div>
