---
/**
 * Logo component
 * Handles light/dark theme logo switching based on dark mode class
 * Responsive sizing: 40px height on mobile, 48px on desktop
 */

import { useTranslations } from "@/i18n/utils";

interface Props {
  href?: string;
}

const { href = "#" } = Astro.props;
const t = useTranslations(Astro.currentLocale);

// Standard logo dimensions maintaining 2.4:1 aspect ratio
// Mobile: 96px × 40px
// Desktop: 115px × 48px
---

<a href={href} class="shrink-0" aria-label={t("header.logo")}>
  <img
    src="/logo-dark.svg"
    alt="Logo"
    width={115}
    height={48}
    class="hidden h-9 w-auto md:h-11 dark:block"
  />
  <img
    src="/logo.svg"
    alt="Logo"
    width={115}
    height={48}
    class="block h-9 w-auto md:h-11 dark:hidden"
  />
</a>
